# Copy to .env and fill in. .env is git-ignored — never commit real credentials.
# This is the DEFAULT profile. For more orgs, see azdo-profiles.example.json.
AZDO_ORG=your-org
AZDO_PROJECT=Your Project
# Azure DevOps Personal Access Token with Code: Read & Write scope.
AZDO_PAT=
# Optional: default repo used when you pass a bare PR id instead of a full URL.
AZDO_DEFAULT_REPO=your-repo
